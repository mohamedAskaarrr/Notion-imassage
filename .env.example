APP_NAME=NotionTelegramAssistant
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=file
QUEUE_CONNECTION=sync

# Telegram Bot credentials (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=
# Secret token set when registering the webhook via setWebhook?secret_token=...
TELEGRAM_WEBHOOK_SECRET=

# Google Gemini API (free tier: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Notion integration (https://www.notion.so/my-integrations)
NOTION_API_KEY=
NOTION_TASKS_DATABASE_ID=
NOTION_IDEAS_DATABASE_ID=
NOTION_VERSION=2022-06-28
